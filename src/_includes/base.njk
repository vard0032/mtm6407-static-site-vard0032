<style>
  body {
  font-family: 'Poppins', sans-serif;
}

  .hero {
  height: 80vh;
  background: url('../assets/images/hero.png')center/cover no-repeat;
  position: relative;
}

.hero::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
}

.hero .container {
  position: relative;
  z-index: 2;
}

.card {
  border: none;
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-5px);
}

.card img {
  height: 200px;
  object-fit: cover;
}

form {
  background: #f8f9fa;
  padding: 20px;
  border-radius: 10px;
}

.contact-img {
  max-height: 400px;
  width: 100%;
  object-fit: cover;
  border-radius: 10px;
}

.card {
  border: none;
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

h1, h2, h5 {
  font-weight: 600;
}
